# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/agri-platform?retryWrites=true&w=majority

# JWT (minimum 32 characters)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins)
# Production: set to your frontend domain, e.g. https://synergycrops.com
CORS_ORIGINS=http://localhost:5173

# Admin seeding (optional — used by npm run seed:admin)
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@synergycrops.com
ADMIN_PASSWORD=changeme

# Logging
LOG_LEVEL=debug

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
